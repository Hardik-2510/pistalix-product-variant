# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in real values.
# On the droplet, .env is read by docker-compose (env_file).
# NEVER commit the real .env — it is gitignored & dockerignored.
# ─────────────────────────────────────────────────────────────

# ── Shopify app credentials (from Partner Dashboard) ──
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://apppov.pistalix.in
SCOPES=read_cart_transforms,read_draft_orders,read_files,write_cart_transforms,write_draft_orders,write_files,write_metaobject_definitions,write_metaobjects,write_products

# Cart price override Shopify Function id — OPTIONAL.
# The app now auto-discovers the cart_transform function, so this can stay blank.
SHOPIFY_CART_PRICE_OVERRIDE_ID=

# Billing: leave unset/false for LIVE charges in production.
# Set to "true" ONLY on a dev store to create test (non-charging) subscriptions.
SHOPIFY_BILLING_TEST=false

# ── Database ──
# Production (inside Docker) is set automatically to file:/data/prod.sqlite.
# For LOCAL development only, use a relative path:
DATABASE_URL=file:./dev.sqlite

# ── DigitalOcean Spaces (S3-compatible object storage) ──
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=blr1
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
SPACES_BUCKET=your-space-name
SPACES_CDN_URL=https://your-space-name.blr1.cdn.digitaloceanspaces.com
# Root folder this app owns inside the Space (keeps its files separate
# from your other content). All uploads go under: <SPACES_FOLDER>/<shop>/...
SPACES_FOLDER=varify-product-options
